<Window x:Class="SeeloewenCraft.wndLog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SeeloewenCraft"
        mc:Ignorable="d"
        Title="Debug-Log" Height="573" Width="973" WindowStartupLocation="CenterScreen">
    <Window.Background>
        <ImageBrush ImageSource="/Resources/Background.png"/>
    </Window.Background>
    <Grid>
        <RichTextBox x:Name="rtbLog" Canvas.Left="10" Canvas.Top="47" FontSize="16" Margin="11,56,11,10" IsReadOnly="True" VerticalScrollBarVisibility="Auto">
            <FlowDocument/>
        </RichTextBox>
        <TextBlock x:Name="tblHeader" Canvas.Left="16" TextWrapping="Wrap" Canvas.Top="10" HorizontalAlignment="Left" VerticalAlignment="Top" FontSize="26" FontWeight="DemiBold" Margin="11,11,0,0"><Run Language="de-de" Text="Debug-Log"/></TextBlock>
        <Button x:Name="btnSave" Content="Save" Canvas.Left="687" Canvas.Top="8" Height="32" VerticalAlignment="Top" FontSize="18" Margin="0,12,401,0" HorizontalAlignment="Right" Width="116" Click="btnSave_Click"/>
        <Button x:Name="btnClear" Content="Clear" Canvas.Left="573" Canvas.Top="8" FontSize="18" Margin="0,12,142,0" Height="32" VerticalAlignment="Top" HorizontalAlignment="Right" Width="116" Click="btnClear_Click"/>
        <Button x:Name="btnClose" Content="Close" Canvas.Left="458" Canvas.Top="8" FontSize="18" Margin="0,12,12,0" Height="32" VerticalAlignment="Top" HorizontalAlignment="Right" Width="116" Click="btnClose_Click"/>
        <Button x:Name="btnFind" Content="Find" Height="32" VerticalAlignment="Top" FontSize="18" Margin="0,12,271,0" HorizontalAlignment="Right" Width="116" Click="btnSave_Click"/>
    </Grid>
</Window>
