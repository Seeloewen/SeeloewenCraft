<Window x:Class="SeeloewenCraft.wndAbout"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SeeloewenCraft"
        mc:Ignorable="d"
        Title="About" Height="571" Width="488" WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Window.Background>
        <ImageBrush ImageSource="/Resources/Textures/Gui/Background.png"/>
    </Window.Background>
    <Grid>
        <TextBlock x:Name="tblHeader" HorizontalAlignment="Left" Margin="65,10,0,0" TextWrapping="Wrap" VerticalAlignment="Top" FontSize="50" FontWeight="DemiBold" Foreground="White"><Run Language="de-de" Text="SeeloewenCraft"/></TextBlock>
        <TextBlock x:Name="tblVersion" HorizontalAlignment="Left" Margin="39,71,0,0" TextWrapping="Wrap" Text="Version {0}" VerticalAlignment="Top" FontSize="20" TextAlignment="Center" Width="396" Foreground="White"/>
        <TextBlock x:Name="tblDeveloperName" HorizontalAlignment="Left" Margin="174,98,0,0" TextWrapping="Wrap" VerticalAlignment="Top" FontSize="20" Foreground="White"><Run Language="de-de" Text="By "/><Run Text="Seeloewen"/></TextBlock>
        <TabControl x:Name="tcAbout" Margin="10,144,0,0" HorizontalAlignment="Left" Width="447" Height="334" VerticalAlignment="Top">
            <TabItem x:Name="tiAbout" Header="About">
                <Canvas x:Name="cvsAbout">
                    <TextBox x:Name="tbAbout" Canvas.Left="10" TextWrapping="Wrap" Text="SeeloewenCraft is a 2D Sandbox game, inspired by Minecraft. It is not meant to copy or replace Minecraft in any way. Please contact Seeloewen on Discord for any legal issues.&#xD;&#xA;&#xD;&#xA;This project is a private project that is not meant to be shared publicly, only with certain friends. Please do not create and share copies of the game, if you happen to have any.&#xD;&#xA;&#xD;&#xA;Please note that development of this game may not be consistant and might stop entirely at some point. Afterall, it's just a fun test project that I'm using to improve my coding skills. If you have any ideas for the game, feel free to share them with me!" Canvas.Top="10" Width="421" Height="286" IsReadOnly="True" FontSize="14" VerticalScrollBarVisibility="Auto"/>
                </Canvas>
            </TabItem>
            <TabItem x:Name="tiChangelog" Header="Changelog">
                <Canvas x:Name="cvsChangelog">
                    <TextBox x:Name="tbChangelog" Canvas.Left="10" TextWrapping="Wrap" Canvas.Top="10" Width="421" Height="286" FontSize="14" IsReadOnly="True" ScrollViewer.CanContentScroll="True" VerticalScrollBarVisibility="Auto"/>
                </Canvas>
            </TabItem>
            <TabItem x:Name="tiSpecialThanks" Header="Special Thanks">
                <Canvas x:Name="cvsSpecialThanks">
                    <TextBox x:Name="tbSpecialThanks" Canvas.Left="10" TextWrapping="Wrap" Text="Special thanks to CDLemmi for being an active contributer and helping on many features of the game, most notably the movement physics, collisions (after Alpha 1.1.4) and entities.&#xA;&#xA;Special thanks to Finni for helping me find many issues by testing developmen versions and also for giving a lot of ideas.&#xD;&#xA;&#xD;&#xA;Special thanks to Axogurkel for helping me create the crafting recipes." Canvas.Top="10" Width="421" Height="286" FontSize="14" IsReadOnly="True" VerticalScrollBarVisibility="Auto"/>
                </Canvas>
            </TabItem>
            <TabItem Header="Third-Party Libraries">
                <Canvas x:Name="cvsThirdParty">
                    <TextBox x:Name="tbThirdParty" Canvas.Left="10" TextWrapping="Wrap" Canvas.Top="10" Width="421" Height="286" FontSize="14" IsReadOnly="True" Text="OpenTK (https://github.com/opentk/opentk)&#xD;&#xA;MIT License&#xD;&#xA;&#xD;&#xA;Copyright (c) 2006-2019 Stefanos Apostolopoulos for the Open Toolkit project.&#xD;&#xA;&#xD;&#xA;Permission is hereby granted, free of charge, to any person obtaining a copy of this software and associated documentation files (the &quot;Software&quot;), to deal in the Software without restriction, including without limitation the rights to use, copy, modify, merge, publish, distribute, sublicense, and/or sell copies of the Software, and to permit persons to whom the Software is furnished to do so, subject to the following conditions:&#xD;&#xA;&#xD;&#xA;The above copyright notice and this permission notice shall be included in all copies or substantial portions of the Software.&#xD;&#xA;&#xD;&#xA;THE SOFTWARE IS PROVIDED &quot;AS IS&quot;, WITHOUT WARRANTY OF ANY KIND, EXPRESS OR IMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRANTIES OF MERCHANTABILITY, FITNESS FOR A PARTICULAR PURPOSE AND NONINFRINGEMENT. IN NO EVENT SHALL THE AUTHORS OR COPYRIGHT HOLDERS BE LIABLE FOR ANY CLAIM, DAMAGES OR OTHER LIABILITY, WHETHER IN AN ACTION OF CONTRACT, TORT OR OTHERWISE, ARISING FROM, OUT OF OR IN CONNECTION WITH THE SOFTWARE OR THE USE OR OTHER DEALINGS IN THE SOFTWARE.&#xD;&#xA;&#xD;&#xA;-----------------------------------------------------------------------&#xD;&#xA;&#xD;&#xA;GLWpfControl (https://github.com/opentk/GLWpfControl)&#xD;&#xA;MIT License&#xD;&#xA;&#xD;&#xA;Copyright (c) 2019 varon&#xD;&#xA;&#xD;&#xA;Permission is hereby granted, free of charge, to any person obtaining a copy of this software and associated documentation files (the &quot;Software&quot;), to deal in the Software without restriction, including without limitation the rights to use, copy, modify, merge, publish, distribute, sublicense, and/or sell copies of the Software, and to permit persons to whom the Software is furnished to do so, subject to the following conditions:&#xD;&#xA;&#xD;&#xA;The above copyright notice and this permission notice shall be included in all copies or substantial portions of the Software.&#xD;&#xA;&#xD;&#xA;THE SOFTWARE IS PROVIDED &quot;AS IS&quot;, WITHOUT WARRANTY OF ANY KIND, EXPRESS OR IMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRANTIES OF MERCHANTABILITY, FITNESS FOR A PARTICULAR PURPOSE AND NONINFRINGEMENT. IN NO EVENT SHALL THE AUTHORS OR COPYRIGHT HOLDERS BE LIABLE FOR ANY CLAIM, DAMAGES OR OTHER LIABILITY, WHETHER IN AN ACTION OF CONTRACT, TORT OR OTHERWISE, ARISING FROM, OUT OF OR IN CONNECTION WITH THE SOFTWARE OR THE USE OR OTHER DEALINGS IN THE SOFTWARE.&#xD;&#xA;&#xD;&#xA;-----------------------------------------------------------------------&#xD;&#xA;&#xD;&#xA;HighPrecisionTimer (https://github.com/mzboray/HighPrecisionTimer)&#xA;MIT License&#xA;&#xA;Copyright (c) 2016 Mike Zboray&#xA;&#xA;Permission is hereby granted, free of charge, to any person obtaining a copy of this software and associated documentation files (the &quot;Software&quot;), to deal in the Software without restriction, including without limitation the rights to use, copy, modify, merge, publish, distribute, sublicense, and/or sell copies of the Software, and to permit persons to whom the Software is furnished to do so, subject to the following conditions:&#xA;&#xA;The above copyright notice and this permission notice shall be included in all copies or substantial portions of the Software.&#xA;&#xA;THE SOFTWARE IS PROVIDED &quot;AS IS&quot;, WITHOUT WARRANTY OF ANY KIND, EXPRESS OR IMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRANTIES OF MERCHANTABILITY, FITNESS FOR A PARTICULAR PURPOSE AND NONINFRINGEMENT. IN NO EVENT SHALL THE AUTHORS OR COPYRIGHT HOLDERS BE LIABLE FOR ANY CLAIM, DAMAGES OR OTHER LIABILITY, WHETHER IN AN ACTION OF CONTRACT, TORT OR OTHERWISE, ARISING FROM,&#xA;OUT OF OR IN CONNECTION WITH THE SOFTWARE OR THE USE OR OTHER DEALINGS IN THE SOFTWARE.&#xA;&#xA;-----------------------------------------------------------------------&#xA;&#xA;Json.NET (https://github.com/JamesNK/Newtonsoft.Json)&#xA;The MIT License (MIT)&#xA;&#xA;Copyright (c) 2007 James Newton-King&#xA;&#xA;Permission is hereby granted, free of charge, to any person obtaining a copy of this software and associated documentation files (the &quot;Software&quot;), to deal in the Software without restriction, including without limitation the rights to use, copy, modify, merge, publish, distribute, sublicense, and/or sell copies of the Software, and to permit persons to whom the Software is furnished to do so, subject to the following conditions:&#xA;&#xA;The above copyright notice and this permission notice shall be included in all copies or substantial portions of the Software.&#xA;&#xA;THE SOFTWARE IS PROVIDED &quot;AS IS&quot;, WITHOUT WARRANTY OF ANY KIND, EXPRESS OR IMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRANTIES OF MERCHANTABILITY, FITNESS FOR A PARTICULAR PURPOSE AND NONINFRINGEMENT. IN NO EVENT SHALL THE AUTHORS OR COPYRIGHT HOLDERS BE LIABLE FOR ANY CLAIM, DAMAGES OR OTHER LIABILITY, WHETHER IN AN ACTION OF CONTRACT, TORT OR OTHERWISE, ARISING FROM, OUT OF OR IN CONNECTION WITH THE SOFTWARE OR THE USE OR OTHER DEALINGS IN THE SOFTWARE." VerticalScrollBarVisibility="Auto"/>
                </Canvas>
            </TabItem>
        </TabControl>
        <Button x:Name="btnOK" Content="OK" HorizontalAlignment="Left" Margin="145,493,0,0" VerticalAlignment="Top" Height="28" Width="188" FontSize="16" Click="btnOK_Click"/>
    </Grid>
</Window>
