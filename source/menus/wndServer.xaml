<Window x:Class="SeeloewenCraft.wndServer"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SeeloewenCraft"
        mc:Ignorable="d"
        Title="wndServer" Height="170" Width="371">
    <Grid>
        <TextBox x:Name="tbIp" HorizontalAlignment="Left" Margin="10,63,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="224" FontSize="16"/>
        <TextBlock x:Name="tblHeader" HorizontalAlignment="Left" Margin="10,10,0,0" TextWrapping="Wrap" Text="Connect to server..." VerticalAlignment="Top" FontSize="16" FontWeight="DemiBold"/>
        <TextBox x:Name="tbPort" HorizontalAlignment="Left" Margin="248,63,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="90" FontSize="16"/>
        <TextBlock x:Name="tblIpHeader" HorizontalAlignment="Left" Margin="10,36,0,0" TextWrapping="Wrap" VerticalAlignment="Top" FontSize="16" Width="390"><Run Text="IP Address                          "/><Run Text="  "/><Run Language="de-de" Text="         "/><Run Text=" "/><Run Text="Port"/></TextBlock>
        <Button x:Name="btnConnect" Content="Connect" HorizontalAlignment="Left" Margin="186,98,0,0" VerticalAlignment="Top" Height="22" Width="152" FontSize="14" Click="btnConnect_Click"/>

    </Grid>
</Window>
